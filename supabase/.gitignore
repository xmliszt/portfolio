# Supabase
.branches
.temp

# dotenvx
.env.keys
.env.local
.env.*.local

# Ignore uploaded storage files by default but keep small SVG placeholders and docs
# This prevents large binary photos from being committed accidentally.
supabase/storage/photos/*
!supabase/storage/photos/*.svg
!supabase/storage/photos/.gitkeep
!supabase/storage/photos/README.md
